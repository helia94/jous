# Google Search Console reporting auth.
#
# Option A: short-lived OAuth access token.
# Use this for quick local runs.
GOOGLE_ACCESS_TOKEN=

# Option B: service-account JSON credentials path.
# Use this for repeatable local/CI runs after adding the service account as a
# user on the verified Search Console property.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/search-console-service-account.json

# Optional defaults for backend/scripts/search_console_report.py.
SEARCH_CONSOLE_SITE_URL=https://jous.app/
SEARCH_CONSOLE_QUERY_CONTAINS=conversation cards
